    },
    "cluster.mirror1.explanation" : {
      "comment" : "Pip Count cluster",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Stellung zeigt zwei Beispiele, wie man ein Cluster aus acht Steinen auf einmal zählt, als wären es acht 5er = 40.\n\nSpieler = 40. Gegner = 40."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This position shows two examples of counting a cluster of eight checkers all at once as if they were eight 5's = 40.\n\nPlayer = 40. Opponent = 40."
          }
        }
      }
    },
    "cluster.mirror2.caption" : {
      "comment" : "Pip Count cluster",
      "extractionState" : "manual",
      "localizations" : {
