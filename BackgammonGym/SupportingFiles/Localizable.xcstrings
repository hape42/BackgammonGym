    "cluster.shift1.caption": {
      "comment": "Pip Count cluster",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einseitiges Verschieben"
          }
        },
        "en": {
