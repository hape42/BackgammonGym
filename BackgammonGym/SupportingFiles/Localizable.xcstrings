    "moremodules.body" : {
      "comment" : "More modules",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Backgammon Gym ist ein freies, werbefreies, quelloffenes Gemeinschaftsprojekt. Version 1.0 ist bewusst klein und wächst mit deinen Anregungen.\n\nWir freuen uns über dein Feedback: Welches Modul wünschst du dir als Nächstes? Ist etwas unklar erklärt? Hast du einen Fehler entdeckt? Auch Backgammon-Berater sind herzlich willkommen.\n\nSchreib uns per E-Mail oder eröffne eine Diskussion auf GitHub."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Backgammon Gym is a free, ad-free, open-source community project. Version 1.0 is deliberately small, and it grows with your input.\n\nWe'd love your feedback: which module would you like to see next? Is something explained unclearly? Did you spot a mistake? Backgammon advisors are very welcome too.\n\nWrite to us by email, or open a discussion on GitHub."
          }
        }
      }
    },
